# ============================================
# Supabase Configuration (REQUIRED)
# ============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ============================================
# Optional: Supabase Service Role Key
# ============================================
# Only needed for admin operations (e.g., seed scripts)
# Get from: https://supabase.com/dashboard/project/_/settings/api
# WARNING: Never expose this in client-side code!
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# Optional: Direct Database URL
# ============================================
# Only needed if using Prisma or direct PostgreSQL access
# Get from: https://supabase.com/dashboard/project/_/settings/database
# DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# ============================================
# Vercel Analytics (auto-configured on Vercel)
# ============================================
# No configuration needed - Analytics component handles this automatically
